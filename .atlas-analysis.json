  "keyFeatures": [
    "Checkout payment flow with WebView",
    "Pay With PayMaya single payment and wallet link creation",
    "Payment Vault for card tokenization",
    "Sandbox and production environment support",
    "Payment status checking",
    "Built-in error handling and exceptions"
  ],
  "publicApiSurface": [
